	(footprint "GCT_USB4160-03-0230-C_USB_C_Vertical"
		(layer "B.Cu")
		(uuid "479dd80e-4ec9-4714-9461-454ac2662e9f")
		(at 16.4001 41.5565 180)
		(descr "GCT USB4160-03-0230-C vertical USB 3.2 Gen2 Type-C receptacle, 24 SMT contacts + 4 soldered shell-stake slots + 2 locating pegs; H=7.46mm, 2.30mm stakes. Signal pads per the vendor CAD footprint supplied by the user (KiCADv6/CONN_USB4160-03-0230-C_GCT), which this file cleans up: the 4 stake slots are made PLATED and mapped to pad SH (GCT drawing sheet 2/4 marks them Solder Area; slot 1.10x0.61 drill, 1.60x1.10 pad, at +-4.00/+-1.43), pegs normalized to NPTH (~O0.71, right one slotted +0.2mm), stray Edge.Cuts/S_3 artifacts removed. Only USB 2.0 subset used in this design (16P symbol): A2/A3/A10/A11/B2/B3/B10/B11 (SS pairs) are left unconnected. Cross-check vs GCT drawing before fab.")
		(tags "USB Type-C vertical receptacle GCT USB4160 SMT")
		(property "Reference" "J1"
			(at 0 3.6 0)
			(layer "B.SilkS")
			(uuid "0e61ab10-bae9-4d45-bd0f-ac2578f75a60")
